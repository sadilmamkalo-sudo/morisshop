{
  "name": "morisshop",
  "version": "1.0.0",
  "description": "MORISSESHOP - E-commerce Platform",
  "scripts": {
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "cd server && npm install && cd ../client && npm install",
    "seed": "cd server && node utils/seed.js",
    "start": "cd server && npm start"
  },
  "keywords": [
    "ecommerce",
    "morocco",
    "shop"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
